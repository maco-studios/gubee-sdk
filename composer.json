{
    "name": "gubee/sdk",
    "type": "library",
    "description": "Gubee SDK for PHP",
    "keywords": [
        "gubee",
        "sdk",
        "api",
        "client"
    ],
    "require": {
        "php": "^7.4",
        "laminas/laminas-hydrator": "^4.5",
        "php-http/client-common": "^2.7",
        "php-http/multipart-stream-builder": "^1.3",
        "psr/http-client": "^1.0",
        "psr/http-factory": "^1.0",
        "psr/log": "^1.1"
    },
    "require-dev": {
        "captainhook/captainhook": "^5.18",
        "fakerphp/faker": "^1.23",
        "laminas/laminas-coding-standard": "^2.5",
        "laminas/laminas-diactoros": "^2.17",
        "monolog/monolog": "^2.9",
        "php-http/curl-client": "^2.3",
        "phpcompatibility/php-compatibility": "^9.3",
        "phpunit/phpunit": "^9.6",
        "squizlabs/php_codesniffer": "^3.8",
        "symfony/cache": "^5.4"
    },
    "autoload": {
        "psr-4": {
            "Gubee\\SDK\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Gubee\\SDK\\Test\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true,
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "scripts": {
        "cs": [
            "@cs:check",
            "@cs:fix"
        ],
        "cs:check": "phpcs",
        "cs:fix": "phpcbf",
        "cs:setup": "vendor/bin/phpcs --config-set installed_paths ../../laminas/laminas-coding-standard/src,../../phpcompatibility/php-compatibility,../../slevomat/coding-standard,../../webimpress,../../webimpress/coding-standard/src",
        "test": [
            "@test:unit",
            "@test:integration"
        ],
        "test:unit": "phpunit --testsuite=Unit",
        "test:integration": "phpunit --testsuite=Integration",
        "post-install-cmd": [
            "@cs:setup",
            "@capitanhook:install"
        ],
        "post-update-cmd": [
            "@cs:setup",
            "@capitanhook:install"
        ],
        "capitanhook:install": "vendor/bin/captainhook install -f"
    }
}
