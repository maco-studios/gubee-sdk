{
    "name": "gubee/sdk",
    "type": "library",
    "description": "Gubee SDK for PHP",
    "keywords": ["gubee", "sdk", "api", "client"],
    "require": {
        "php-http/client-common": "^2.7",
        "psr/http-client": "^1.0",
        "psr/http-factory": "^1.0",
        "psr/log": "^3.0"
    },
    "require-dev": {
        "captainhook/captainhook": "^5.21",
        "squizlabs/php_codesniffer": "^3.8",
        "phpcompatibility/php-compatibility": "^9.3",
        "phpunit/phpunit": "^11.0",
        "php-http/curl-client": "^2.3",
        "laminas/laminas-diactoros": "^3.3",
        "laminas/laminas-coding-standard": "^2.5"
    },
    "autoload": {
        "psr-4": {
            "Gubee\\SDK\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Gubee\\SDK\\Test\\":"tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true,
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "scripts": {
        "cs": [
            "@cs:check",
            "@cs:fix"
        ],
        "cs:check": "phpcs",
        "cs:fix": "phpcbf",
        "cs:setup": "vendor/bin/phpcs --config-set installed_paths vendor/laminas/laminas-coding-standard,vendor/phpcompatibility/php-compatibility,vendor/webimpress/coding-standard/src",
        "test": [
            "@test:unit",
            "@test:integration"
        ],
        "test:unit": "phpunit --testsuite=Unit",
        "test:integration": "phpunit --testsuite=Integration",
        "post-install-cmd": [
            "@cs:setup",
            "@capitanhook:install"
        ],
        "post-update-cmd": [
            "@cs:setup",
            "@capitanhook:install"
        ],
        "capitanhook:install": "vendor/bin/captainhook install -f"
    }
}
